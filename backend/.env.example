# ─── Foresite backend env vars ────────────────────────────────────────────────
# Copy to .env (never commit). For production EC2: place at /opt/foresite/.env
# with `chmod 600`.

# Mode — anything other than "production" allows dev defaults (wide CORS, dev secret).
ENV=production

# Required: at least 32 bytes of randomness. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Required: PostgreSQL URL. For RDS use the writer endpoint, port 5432.
# Example: postgresql://postgres:hunter2@foresite-db.xxxx.eu-west-1.rds.amazonaws.com:5432/postgres
DATABASE_URL=

# Required: comma-separated list of allowed frontend origins (no trailing slash).
# Add every domain the frontend is served from — production + custom domain + previews.
BACKEND_CORS_ORIGINS=https://smart-construction-zeta.vercel.app

# Required: URL the frontend is served at (used in email links — must be the
# domain users actually visit, no trailing slash).
FRONTEND_URL=https://smart-construction-zeta.vercel.app

# Required if you use Google Sign-In on the frontend. Must match
# NEXT_PUBLIC_GOOGLE_CLIENT_ID in the Vercel project.
GOOGLE_CLIENT_ID=

# ─── Email (pick ONE option) ──────────────────────────────────────────────────
# Option A: Resend (HTTP API — works behind locked-down egress firewalls)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Foresite <noreply@yourdomain.com>

# Option B: SMTP (Gmail app passwords, etc.). Leave blank if using Resend.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=
# SMTP_PASSWORD=

# ─── File storage ─────────────────────────────────────────────────────────────
# Required for production: photo uploads go to Cloudinary so they survive
# container/EC2 replacement. Leave blank to fall back to local backend/uploads/
# (ephemeral, not safe for prod).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Container port — usually leave this as 8000 ──────────────────────────────
PORT=8000
