# ─── Foresite frontend env vars ───────────────────────────────────────────────
# Copy this file to .env.local for local dev. In production (Vercel), set
# these in the project's Environment Variables UI instead of committing a file.

# Backend API origin. Must include the /api/v1 prefix.
# Local dev:     http://localhost:8000/api/v1
# Production:    https://api.yourdomain.com/api/v1  (or your EC2 public URL)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Google Sign-In (optional). Must match GOOGLE_CLIENT_ID on the backend.
# Get one at https://console.cloud.google.com/apis/credentials
# Authorize https://yourdomain.com + https://<project>.vercel.app as origins.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
